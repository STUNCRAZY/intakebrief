# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=
# Sandbox redirect: when set, ALL outbound email goes here instead of the real
# recipient; the original recipient is noted in the subject suffix "[TEST -> ...]".
TEST_INBOX_ADDRESS=
# JSON map of firm id -> notification inbox, e.g. {"some-firm":"intake@firm.com"}
FIRM_RECIPIENTS_JSON='{"<firmId>":"email"}'

# --- Calendar (Google Calendar) ---
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- Demo mode ---
# Set to 'true' only for local sales demos — serves clearly-labeled sample
# availability and a simulated checkout; never enable in production.
DEMO_MODE=false

# --- App ---
APP_BASE_URL=http://localhost:3000
CALENDAR_TIMEZONE=America/Chicago
INQUIRY_RETENTION_DAYS=30
AUDIT_LOG_PATH=
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=600000

# --- AI (optional; classification ships deterministic, no AI required) ---
AI_PROVIDER=
AI_API_KEY=
